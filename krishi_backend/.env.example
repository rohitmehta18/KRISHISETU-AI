# MongoDB Configuration
# Replace with your MongoDB Atlas connection string
MONGO_URI=mongodb+srv://username:password@cluster0.mongodb.net/krishiDB?appName=Cluster0

# Server Configuration
PORT=3000
NODE_ENV=development

# ESP32 WiFi Configuration
# Local WiFi IP of your ESP32 device (when connected to WiFi)
ESP_BASE_URL=http://192.168.4.1
# Timeout in milliseconds for ESP32 requests
TIMEOUT_MS=5000
